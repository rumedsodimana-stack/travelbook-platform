rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "rumedsodimana@gmail.com";
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidVehicle(data) {
      return data.keys().hasAll(['providerId', 'type', 'model', 'capacity', 'status', 'createdAt']) &&
             data.providerId is string &&
             data.type in ["Car", "Van", "Bus", "Motorcycle"] &&
             (!('make' in data) || data.make is string) &&
             data.model is string && data.model.size() > 0 && data.model.size() < 100 &&
             (!('year' in data) || data.year is number) &&
             (!('color' in data) || data.color is string) &&
             (!('licensePlate' in data) || data.licensePlate is string) &&
             data.capacity is number && data.capacity > 0 && data.capacity < 100 &&
             data.status in ["Pending", "Verified", "Rejected"] &&
             (!('photoUrl' in data) || isValidUrl(data.photoUrl));
    }

    function isValidRideRequest(data) {
      return data.keys().hasAll(['travelerId', 'travelerName', 'origin', 'destination', 'passengers', 'status', 'createdAt']) &&
             data.travelerId is string &&
             data.travelerName is string && data.travelerName.size() > 0 && data.travelerName.size() < 100 &&
             data.origin is string && data.origin.size() > 0 && data.origin.size() < 200 &&
             data.destination is string && data.destination.size() > 0 && data.destination.size() < 200 &&
             data.passengers is number && data.passengers > 0 &&
             data.status in ["Open", "Accepted", "Completed", "Cancelled"] &&
             (!('rideType' in data) || data.rideType in ['standard', 'robotaxi']) &&
             (!('providerId' in data) || data.providerId is string) &&
             (!('vehicleId' in data) || data.vehicleId is string) &&
             (!('vehicleDetails' in data) || data.vehicleDetails is map) &&
             (!('fare' in data) || data.fare is number) &&
             (!('pickupLat' in data) || data.pickupLat is number) &&
             (!('pickupLng' in data) || data.pickupLng is number) &&
             (!('dropoffLat' in data) || data.dropoffLat is number) &&
             (!('dropoffLng' in data) || data.dropoffLng is number) &&
             (!('driverLat' in data) || data.driverLat is number) &&
             (!('driverLng' in data) || data.driverLng is number);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAuthenticated();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.providerId) || isAdmin());
      allow create: if isAuthenticated() && 
                      isOwner(request.resource.data.providerId) && 
                      isValidVehicle(request.resource.data) &&
                      request.resource.data.status == 'Pending';
      allow update: if isAuthenticated() && 
                      (isOwner(resource.data.providerId) || isAdmin()) &&
                      isValidVehicle(request.resource.data) &&
                      (isAdmin() || (request.resource.data.status == resource.data.status && 
                                    request.resource.data.providerId == resource.data.providerId &&
                                    request.resource.data.createdAt == resource.data.createdAt));
      allow delete: if isAdmin();
    }

    match /rideRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      isOwner(request.resource.data.travelerId) && 
                      isValidRideRequest(request.resource.data) &&
                      request.resource.data.status == 'Open';
      allow update: if isAuthenticated() && 
                      isValidRideRequest(request.resource.data) &&
                      (
                        isOwner(resource.data.travelerId) || 
                        (resource.data.status == 'Open' && request.resource.data.status == 'Accepted' && request.resource.data.providerId == request.auth.uid) ||
                        (resource.data.providerId == request.auth.uid)
                      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && 
                        request.resource.data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
                        request.resource.data.senderId == request.auth.uid &&
                        request.resource.data.text is string &&
                        request.resource.data.text.size() > 0 &&
                        request.resource.data.text.size() <= 500;
      }
    }
  }
}
